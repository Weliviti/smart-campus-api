# Normalise line endings across OSes.
* text=auto eol=lf

# Source code — always LF
*.java      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.properties text eol=lf

# Windows-only — keep CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Treat as binary so git doesn't try to merge
*.jar       binary
*.png       binary
*.jpg       binary
*.pdf       binary
